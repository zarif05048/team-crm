# ============================================================
#  Copy this file to .env.local and fill in real values.
#  NEVER commit .env.local (it is gitignored).
# ============================================================

# --- Supabase (from your Supabase project → Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Service role key — SERVER ONLY, full DB access. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Meta WhatsApp Cloud API (from Meta App → WhatsApp → API setup) ---
# Permanent/system-user access token that can send from your WABA number(s).
WHATSAPP_ACCESS_TOKEN=your-meta-access-token
# Graph API version, e.g. v21.0
WHATSAPP_API_VERSION=v21.0
# A random string you invent; you paste the SAME value into Meta's webhook config.
WHATSAPP_VERIFY_TOKEN=make-up-a-long-random-string
# App Secret (Meta App → Settings → Basic) — used to verify webhook signatures.
META_APP_SECRET=your-meta-app-secret
